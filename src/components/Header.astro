---
import IconX from "@/assets/icons/IconX.svg";
import IconMoon from "@/assets/icons/IconMoon.svg";
import IconSearch from "@/assets/icons/IconSearch.svg";
import IconArchive from "@/assets/icons/IconArchive.svg";
import IconSunHigh from "@/assets/icons/IconSunHigh.svg";
import IconMenuDeep from "@/assets/icons/IconMenuDeep.svg";
import LinkButton from "./LinkButton.astro";
import { SITE } from "@/config";

const { pathname } = Astro.url;

// Remove trailing slash from current pathname if exists
const currentPath =
  pathname.endsWith("/") && pathname !== "/" ? pathname.slice(0, -1) : pathname;

const isActive = (path: string) => {
  const currentPathArray = currentPath.split("/").filter(p => p.trim());
  const pathArray = path.split("/").filter(p => p.trim());

  return currentPath === path || currentPathArray[0] === pathArray[0];
};
---

<a
  id="skip-to-content"
  href="#main-content"
  class="absolute start-16 -top-full z-50 rounded-b-md bg-background/80 px-3 py-2 text-accent backdrop-blur-sm transition-all focus:top-4"
>
  Skip to content
</a>

<header
  id="main-header"
  class="sticky top-0 z-40 w-full transition-all duration-300"
>
  <div
    id="top-nav-wrap"
    class="app-layout relative w-full py-4 transition-all duration-300 sm:py-6"
  >
    <div class="relative flex items-baseline justify-between sm:items-center">
      <a
        href="/"
        class="group relative py-1 text-xl font-semibold leading-8 transition-colors hover:text-accent sm:static sm:my-auto sm:text-2xl sm:leading-none"
      >
        {SITE.title}
      </a>
      <nav id="nav-menu" class="flex w-full flex-col items-center sm:ms-2 sm:flex-row sm:justify-end sm:space-x-4 sm:py-0">
        <button
          id="menu-btn"
          class="focus-outline self-end rounded-lg p-2 transition-all hover:bg-accent/10 sm:hidden"
          aria-label="Open Menu"
          aria-expanded="false"
          aria-controls="menu-items"
        >
          <IconX id="close-icon" class="hidden" />
          <IconMenuDeep id="menu-icon" />
        </button>

        <!-- Mobile + Desktop Menu Panel -->
        <ul
          id="menu-items"
          class="mobile-menu-panel sm:static sm:flex sm:flex-row sm:items-center sm:gap-5 sm:bg-transparent sm:backdrop-blur-none sm:p-0 sm:shadow-none"
        >
          <li>
            <a href="/posts" class:list={["nav-link", { "active-nav": isActive("/posts") }]}>
              Posts
            </a>
          </li>
          <li>
            <a href="/tags" class:list={["nav-link", { "active-nav": isActive("/tags") }]}>
              Tags
            </a>
          </li>
          <li>
            <a href="/about" class:list={["nav-link", { "active-nav": isActive("/about") }]}>
              About
            </a>
          </li>
          {
            SITE.showArchives && (
              <li>
                <LinkButton
                  href="/archives"
                  class:list={[
                    "nav-link flex justify-center",
                    { "active-nav [&>svg]:stroke-accent": isActive("/archives") },
                  ]}
                  title="Archives"
                  aria-label="archives"
                >
                  <IconArchive class="hidden sm:inline-block" />
                  <span class="sm:sr-only">Archives</span>
                </LinkButton>
              </li>
            )
          }
          <li class="flex items-center justify-center">
            <LinkButton
              href="/search"
              class:list={[
                "nav-link flex justify-center",
                { "[&>svg]:stroke-accent": isActive("/search") },
              ]}
              title="Search"
              aria-label="search"
            >
              <IconSearch />
              <span class="sr-only">Search</span>
            </LinkButton>
          </li>
          {
            SITE.lightAndDarkMode && (
              <li class="flex items-center justify-center">
                <button
                  id="theme-btn"
                  class="nav-link flex justify-center"
                  title="Toggles light & dark"
                  aria-label="auto"
                  aria-live="polite"
                >
                  <IconMoon class="absolute top-[50%] left-[50%] -translate-[50%] scale-100 rotate-0 transition-all dark:scale-0 dark:-rotate-90" />
                  <IconSunHigh class="absolute top-[50%] left-[50%] -translate-[50%] scale-0 rotate-90 transition-all dark:scale-100 dark:rotate-0" />
                </button>
              </li>
            )
          }
        </ul>
      </nav>
    </div>
  </div>
  <div
    id="header-border"
    class="h-px w-full bg-gradient-to-r from-transparent via-border/40 to-transparent opacity-0 transition-opacity duration-300"
  ></div>
</header>

<style>
  /* ===== Scroll Glass Effect ===== */
  #main-header {
    background: transparent;
  }

  .header-scrolled #top-nav-wrap {
    padding-top: 0.75rem !important;
    padding-bottom: 0.75rem !important;
  }

  .header-scrolled {
    background: color-mix(in srgb, var(--background) 85%, transparent) !important;
    backdrop-filter: blur(12px) saturate(180%);
    -webkit-backdrop-filter: blur(12px) saturate(180%);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
  }

  /* ===== Mobile Menu Glass Panel ===== */
  .mobile-menu-panel {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 30;
    background: color-mix(in srgb, var(--background) 90%, transparent);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    padding: 5rem 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    transition:
      opacity 0.3s ease,
      visibility 0.3s ease;
    opacity: 0;
    visibility: hidden;
  }

  .mobile-menu-panel.is-open {
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu-panel ul {
    width: 100%;
    max-width: 20rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .mobile-menu-panel li {
    width: 100%;
  }

  .mobile-menu-panel .nav-link {
    display: block;
    width: 100%;
    padding: 0.75rem 1rem;
    text-align: center;
    font-size: 1.125rem;
    border-radius: 0.75rem;
    background: transparent;
    transition: all 0.2s ease;
  }

  .mobile-menu-panel .nav-link:hover {
    background: color-mix(in srgb, var(--accent) 15%, transparent);
    color: var(--accent);
  }

  .mobile-menu-panel .active-nav {
    color: var(--accent);
  }

  /* Override desktop styles inside the panel */
  @media (min-width: 640px) {
    .mobile-menu-panel {
      position: static;
      background: transparent;
      backdrop-filter: none;
      padding: 0;
      opacity: 1;
      visibility: visible;
      flex-direction: row;
      justify-content: flex-end;
    }
    .mobile-menu-panel ul {
      flex-direction: row;
      max-width: none;
      gap: 0.5rem;
    }
    .mobile-menu-panel li {
      width: auto;
    }
    .mobile-menu-panel .nav-link {
      width: auto;
      padding: 0.375rem 0.75rem;
      font-size: 0.875rem;
    }
  }

  /* ===== Active Nav Indicator (Desktop) ===== */
  .active-nav {
    position: relative;
    color: var(--accent) !important;
  }

  @media (min-width: 640px) {
    .active-nav::after {
      content: "";
      position: absolute;
      bottom: -4px;
      left: 50%;
      transform: translateX(-50%);
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background-color: var(--accent);
      box-shadow: 0 0 6px color-mix(in srgb, var(--accent) 80%, transparent);
    }
  }

  /* ===== Logo hover ===== */
  .group:hover {
    text-shadow: 0 0 2px color-mix(in srgb, var(--accent) 30%, transparent);
  }

  /* ===== Theme button icons positioning (keep original) ===== */
  #theme-btn {
    position: relative;
    width: 2rem;
    height: 2rem;
  }
</style>

<script>
  function setupScrollGlass() {
    const header = document.getElementById("main-header");
    const border = document.getElementById("header-border");
    if (!header || !border) return;

    let ticking = false;
    const handleScroll = () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrolled = window.scrollY > 15;
          header.classList.toggle("header-scrolled", scrolled);
          border.classList.toggle("opacity-0", !scrolled);
          border.classList.toggle("opacity-100", scrolled);
          ticking = false;
        });
        ticking = true;
      }
    };

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll(); // initial call
  }

  function toggleNav() {
    const menuBtn = document.querySelector("#menu-btn");
    const menuItems = document.querySelector("#menu-items");
    const menuIcon = document.querySelector("#menu-icon");
    const closeIcon = document.querySelector("#close-icon");

    if (!menuBtn || !menuItems || !menuIcon || !closeIcon) return;

    const closeMenu = () => {
      menuBtn.setAttribute("aria-expanded", "false");
      menuBtn.setAttribute("aria-label", "Open Menu");
      menuItems.classList.remove("is-open");
      menuIcon.classList.remove("hidden");
      closeIcon.classList.add("hidden");
      document.body.style.overflow = "";
    };

    const openMenu = () => {
      menuBtn.setAttribute("aria-expanded", "true");
      menuBtn.setAttribute("aria-label", "Close Menu");
      menuItems.classList.add("is-open");
      menuIcon.classList.add("hidden");
      closeIcon.classList.remove("hidden");
      document.body.style.overflow = "hidden";
    };

    // Toggle on button click
    menuBtn.addEventListener("click", () => {
      const isOpen = menuBtn.getAttribute("aria-expanded") === "true";
      if (isOpen) closeMenu();
      else openMenu();
    });

    // Close when clicking a link inside the menu
    menuItems.querySelectorAll("a").forEach(link => {
      link.addEventListener("click", closeMenu);
    });

    // Close on escape key
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menuBtn.getAttribute("aria-expanded") === "true") {
        closeMenu();
      }
    });
  }

  // Initialize
  setupScrollGlass();
  toggleNav();

  // Re-run on view transitions (Astro)
  document.addEventListener("astro:after-swap", () => {
    setupScrollGlass();
    toggleNav();
  });
</script>
